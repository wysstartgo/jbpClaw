diff --git a/src/gateway/chat-attachments.test.ts b/src/gateway/chat-attachments.test.ts
--- a/src/gateway/chat-attachments.test.ts
+++ b/src/gateway/chat-attachments.test.ts
@@ -1,9 +1,11 @@
 import { describe, expect, it, vi } from "vitest";
+import { deleteMediaBuffer } from "../media/store.js";
 import {
   buildMessageWithAttachments,
+  CHAT_SEND_IMAGE_ATTACHMENT_MAX_BYTES,
   type ChatAttachment,
   parseMessageWithAttachments,
 } from "./chat-attachments.js";
 
 const PNG_1x1 =
   "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/woAAn8B9FD5fHAAAAAASUVORK5CYII=";
@@ -136,5 +138,47 @@ describe("parseMessageWithAttachments", () => {
     expect(parsed.images[0]?.mimeType).toBe("image/png");
     expect(parsed.images[0]?.data).toBe(PNG_1x1);
     expect(logs.some((l) => /non-image/i.test(l))).toBe(true);
   });
+
+  it("accepts image attachments over 5MB and under the chat.send 30MiB limit", async () => {
+    const largePng = Buffer.concat([
+      Buffer.from(PNG_1x1, "base64"),
+      Buffer.alloc(5_500_000),
+    ]).toString("base64");
+    const parsed = await parseMessageWithAttachments(
+      "x",
+      [
+        {
+          type: "image",
+          mimeType: "image/png",
+          fileName: "large.png",
+          content: largePng,
+        },
+      ],
+      { log: { warn: () => {} } },
+    );
+
+    try {
+      expect(parsed.images).toHaveLength(0);
+      expect(parsed.offloadedRefs).toHaveLength(1);
+    } finally {
+      await Promise.allSettled(
+        parsed.offloadedRefs.map((ref) => deleteMediaBuffer(ref.id, "inbound")),
+      );
+    }
+  });
+
+  it("rejects image attachments over the 30MiB chat.send limit before decoding", async () => {
+    const oversized = "A".repeat(Math.ceil((CHAT_SEND_IMAGE_ATTACHMENT_MAX_BYTES + 1) / 3) * 4);
+    const fromSpy = vi.spyOn(Buffer, "from");
+    try {
+      await expect(
+        parseMessageWithAttachments("x", [{ type: "image", mimeType: "image/png", fileName: "too-large.png", content: oversized }], { log: { warn: () => {} } }),
+      ).rejects.toThrow(/exceeds size limit/i);
+      const base64Calls = fromSpy.mock.calls.filter((args) => (args as unknown[])[1] === "base64");
+      expect(base64Calls).toHaveLength(0);
+    } finally {
+      fromSpy.mockRestore();
+    }
+  });
 });
