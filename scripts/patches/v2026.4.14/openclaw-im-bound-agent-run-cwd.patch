+export function resolveAgentRunCwd(
+  cfg: OpenClawConfig,
+  agentId: string,
+  overrideCwd?: unknown,
+): string | undefined {
+  const explicit = readStringValue(overrideCwd)?.trim();
+  if (explicit) {
+    return stripNullBytes(resolveUserPath(explicit));
+  }
+  const configured = resolveAgentConfig(cfg, normalizeAgentId(agentId))?.cwd?.trim();
+  const fallback = cfg.agents?.defaults?.cwd?.trim();
+  const resolved = configured || fallback;
+  return resolved ? stripNullBytes(resolveUserPath(resolved)) : undefined;
+}
