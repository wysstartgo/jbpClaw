{
  "appId": "com.lobsterai.app",
  "productName": "JBPClaw",
  "executableName": "JBPClaw",
  "directories": {
    "output": "release"
  },
  "beforePack": "./scripts/electron-builder-hooks.cjs",
  "afterPack": "./scripts/electron-builder-hooks.cjs",
  "files": [
    "package.json",
    "resources/SYSTEM_PROMPT.md",
    {
      "from": "dist",
      "to": "dist",
      "filter": ["**/*"]
    },
    {
      "from": "dist-electron",
      "to": "dist-electron",
      "filter": ["**/*"]
    },
    "!**/*.map",
    "!**/*.d.ts",
    "!**/*.d.cts",
    "!**/*.d.mts",
    "!**/README.md",
    "!**/README",
    "!**/readme.md",
    "!**/CHANGELOG.md",
    "!**/CHANGELOG",
    "!**/HISTORY.md",
    "!**/LICENSE",
    "!**/LICENSE.md",
    "!**/LICENSE.txt",
    "!**/.eslintrc*",
    "!**/.prettierrc*",
    "!**/tsconfig.json",
    "!**/tsconfig.*.json",
    "!**/*.test.*",
    "!**/*.spec.*",
    "!**/tests/**",
    "!**/test/**",
    "!**/__tests__/**"
  ],
  "extraResources": [
    {
      "from": ".keyfrom-build",
      "to": "keyfrom",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "resources/tray",
      "to": "tray",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "resources/pets",
      "to": "pets",
      "filter": [
        "**/*"
      ]
    }
  ],
  "protocols": [
    {
      "name": "JBPClaw",
      "schemes": ["lobsterai"]
    }
  ],
  "mac": {
    "target": [
      "dmg"
    ],
    "icon": "build/icons/png/1024x1024.png",
    "category": "public.app-category.productivity",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "extendInfo": {
      "CFBundleIconName": "icon",
      "NSCalendarsUsageDescription": "JBPClaw 需要访问您的日历来帮助您查看和管理日程安排，例如查找事件、创建会议等。",
      "NSRemindersUsageDescription": "JBPClaw 需要访问您的提醒事项来帮助您管理待办事项。",
      "NSAppleEventsUsageDescription": "JBPClaw 需要使用 Apple Events 来控制 Calendar 应用执行自动化操作。",
      "NSMicrophoneUsageDescription": "JBPClaw 需要访问麦克风以支持聊天输入框中的语音输入。",
      "NSSpeechRecognitionUsageDescription": "JBPClaw 需要使用语音识别将您的语音实时转换为聊天输入文本。"
    },
    "extraResources": [
      {
        "from": "build/generated/macos-speech",
        "to": "macos-speech",
        "filter": [
          "MacSpeechHelper",
          "MacTtsHelper",
          "!module-cache/**",
          "!module-cache-tts/**"
        ]
      },
      {
        "from": "SKILLs",
        "to": "SKILLs",
        "filter": [
          "**/*",
          "!**/.env",
          "!**/.env.*",
          "!**/.venv",
          "!**/.venv/**",
          "!**/*.map",
          "!**/*.d.ts",
          "!**/*.d.cts",
          "!**/*.d.mts",
          "!**/README.md",
          "!**/README",
          "!**/readme.md",
          "!**/CHANGELOG.md",
          "!**/CHANGELOG",
          "!**/HISTORY.md",
          "!**/LICENSE",
          "!**/LICENSE.md",
          "!**/LICENSE.txt",
          "!**/.eslintrc*",
          "!**/.prettierrc*",
          "!**/*.test.*",
          "!**/*.spec.*",
          "!**/tests/**",
          "!**/test/**",
          "!**/__tests__/**"
        ]
      },
      {
        "from": "vendor/openclaw-runtime/current",
        "to": "cfmind",
        "filter": [
          "**/*",
          "!**/*.map",
          "!**/*.d.ts",
          "!**/*.d.cts",
          "!**/*.d.mts",
          "!**/README.md",
          "!**/README",
          "!**/readme.md",
          "!**/CHANGELOG.md",
          "!**/CHANGELOG",
          "!**/HISTORY.md",
          "!**/LICENSE",
          "!**/LICENSE.md",
          "!**/LICENSE.txt",
          "!**/.eslintrc*",
          "!**/.prettierrc*",
          "!**/*.test.*",
          "!**/*.spec.*",
                "!**/tests/**",
          "!**/test/**",
          "!**/__tests__/**"
        ]
      }
    ]
  },
  "dmg": {
    "sign": false
  },
  "afterSign": "scripts/notarize.js",
  "win": {
    "target": [
      "nsis"
    ],
    "icon": "build/icons/win/icon.ico",
    "requestedExecutionLevel": "asInvoker",
    "extraResources": [
      {
        "from": "build-tar/win-resources.tar",
        "to": "win-resources.tar"
      },
      {
        "from": "scripts/unpack-cfmind.cjs",
        "to": "unpack-cfmind.cjs"
      }
    ]
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "icon": "build/icons/png",
    "category": "Utility",
    "extraResources": [
      {
        "from": "SKILLs",
        "to": "SKILLs",
        "filter": [
          "**/*",
          "!**/.env",
          "!**/.env.*",
          "!**/.venv",
          "!**/.venv/**",
          "!**/*.map",
          "!**/*.d.ts",
          "!**/*.d.cts",
          "!**/*.d.mts",
          "!**/README.md",
          "!**/README",
          "!**/readme.md",
          "!**/CHANGELOG.md",
          "!**/CHANGELOG",
          "!**/HISTORY.md",
          "!**/LICENSE",
          "!**/LICENSE.md",
          "!**/LICENSE.txt",
          "!**/.eslintrc*",
          "!**/.prettierrc*",
          "!**/tsconfig.json",
          "!**/tsconfig.*.json",
          "!**/*.test.*",
          "!**/*.spec.*",
          "!**/tests/**",
          "!**/test/**",
          "!**/__tests__/**"
        ]
      },
      {
        "from": "vendor/openclaw-runtime/current",
        "to": "cfmind",
        "filter": [
          "**/*",
          "!**/*.map",
          "!**/*.d.ts",
          "!**/*.d.cts",
          "!**/*.d.mts",
          "!**/README.md",
          "!**/README",
          "!**/readme.md",
          "!**/CHANGELOG.md",
          "!**/CHANGELOG",
          "!**/HISTORY.md",
          "!**/LICENSE",
          "!**/LICENSE.md",
          "!**/LICENSE.txt",
          "!**/.eslintrc*",
          "!**/.prettierrc*",
          "!**/tsconfig.json",
          "!**/tsconfig.*.json",
          "!**/*.test.*",
          "!**/*.spec.*",
                "!**/tests/**",
          "!**/test/**",
          "!**/__tests__/**"
        ]
      }
    ],
    "desktop": {
      "Name": "JBPClaw",
      "Comment": "AI-assisted coding and productivity tool",
      "Terminal": "false"
    }
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "runAfterFinish": true,
    "deleteAppDataOnUninstall": true,
    "include": "scripts/nsis-installer.nsh"
  },
  "electronVersion": "40.2.1",
  "asarUnpack": [
    "node_modules/@anthropic-ai/claude-agent-sdk/**",
    "node_modules/@img/**",
    "node_modules/node-nim/**",
    "node_modules/npm/**"
  ],
  "asar": true
}
